+# SPDX-License-Identifier: (GPL-2.0 OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/spi/amd,pensando-cpld-rd1173.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: AMD Pensando CPLD RD1173 SPI-to-I2C Bridge
+
+description: |
+  SPI-connected Lattice RD1173 I2C controller present on the Pensando
+  Elba/Salina CPLD. It provides two I2C masters and is typically used
+  for transceiver EEPROM / module access.
+
+maintainers:
+  - Brad Larson <bradley.larson@amd.com>
+
+properties:
+  compatible:
+    const: amd,pensando-cpld-rd1173
+
+  reg:
+    maxItems: 1
+
+  spi-max-frequency:
+    maximum: 10000000
+
+  interrupts:
+    maxItems: 1
+
+  interrupt-gpios:
+    maxItems: 1
+
+required:
+  - compatible
+  - reg
+  - spi-max-frequency
+
+additionalProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+    #include <dt-bindings/interrupt-controller/irq.h>
+
+    spi {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        cpld@2 {
+            compatible = "amd,pensando-cpld-rd1173";
+            reg = <2>;
+            spi-max-frequency = <5000000>;
+            interrupt-parent = <&gpio>;
+            interrupts = <22 IRQ_TYPE_LEVEL_LOW>;
+        };
+    };
