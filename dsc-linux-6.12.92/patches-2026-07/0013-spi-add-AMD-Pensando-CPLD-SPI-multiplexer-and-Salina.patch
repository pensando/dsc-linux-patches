From 88fd7da7b10ee740a5005916017bfa32f23bd2c4 Mon Sep 17 00:00:00 2001
From: Brad Larson <bradley.larson@amd.com>
Date: Wed, 24 Jun 2026 12:53:42 -0700
Subject: [PATCH 13/20] spi: add AMD Pensando CPLD SPI multiplexer and Salina
 dw support

Add the AMD Pensando CPLD SPI multiplexer driver and enable the
DesignWare MMIO SPI controller on the Salina SoC, with the spi Kconfig
and Makefile hooks.

The DesignWare MMIO Elba chip-select control is based on internal AMD
Pensando 5.10 work by David Clear.

Signed-off-by: Brad Larson <bradley.larson@amd.com>
---
 drivers/spi/Kconfig           |  15 ++
 drivers/spi/Makefile          |   1 +
 drivers/spi/spi-cpld-spimux.c | 262 ++++++++++++++++++++++++++++++++++
 drivers/spi/spi-dw-mmio.c     |   4 +
 4 files changed, 282 insertions(+)
 create mode 100644 drivers/spi/spi-cpld-spimux.c

diff --git a/drivers/spi/Kconfig b/drivers/spi/Kconfig
index 06c740442fa7..6eb7b5fc7de2 100644
--- a/drivers/spi/Kconfig
+++ b/drivers/spi/Kconfig
@@ -297,6 +297,21 @@ config SPI_COLDFIRE_QSPI
 	  This enables support for the Coldfire QSPI controller in master
 	  mode.
 
+config SPI_CPLD_SPIMUX
+	tristate "AMD Pensando Salina CPLD SPI mux"
+	depends on ARCH_PENSANDO_SALINA_SOC && SPI_MASTER
+	help
+	  This driver supports the CPLD-based SPI multiplexer
+	  present on AMD Pensando Salina platforms.
+
+	  The CPLD requires a register write on chip select 0
+	  to select the downstream SPI target before accessing
+	  devices behind chip selects 1..3.
+
+	  This driver exposes a virtual SPI controller which
+	  performs the required mux sequencing transparently
+	  for SPI clients.
+
 config SPI_CS42L43
 	tristate "Cirrus Logic CS42L43 SPI controller"
 	depends on MFD_CS42L43 && PINCTRL_CS42L43
diff --git a/drivers/spi/Makefile b/drivers/spi/Makefile
index a9b1bc259b68..a5e8c9c0b231 100644
--- a/drivers/spi/Makefile
+++ b/drivers/spi/Makefile
@@ -42,6 +42,7 @@ obj-$(CONFIG_SPI_CADENCE_XSPI)		+= spi-cadence-xspi.o
 obj-$(CONFIG_SPI_CH341)			+= spi-ch341.o
 obj-$(CONFIG_SPI_CLPS711X)		+= spi-clps711x.o
 obj-$(CONFIG_SPI_COLDFIRE_QSPI)		+= spi-coldfire-qspi.o
+obj-$(CONFIG_SPI_CPLD_SPIMUX)		+= spi-cpld-spimux.o
 obj-$(CONFIG_SPI_CS42L43)		+= spi-cs42l43.o
 obj-$(CONFIG_SPI_DAVINCI)		+= spi-davinci.o
 obj-$(CONFIG_SPI_DLN2)			+= spi-dln2.o
diff --git a/drivers/spi/spi-cpld-spimux.c b/drivers/spi/spi-cpld-spimux.c
new file mode 100644
index 000000000000..0a2575c299c7
--- /dev/null
+++ b/drivers/spi/spi-cpld-spimux.c
@@ -0,0 +1,262 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Copyright 2026 Advanced Micro Devices, Inc.
+ */
+
+/*
+ * AMD Pensando Salina CPLD SPI mux
+ *
+ * Background (Elba vs Salina)
+ * ---------------------------
+ *
+ * On Elba, the SPI controller exposes four logical chip selects:
+ * CS0 to the CPLD registers and CS1-CS3 to devices.
+ *
+ *   CS0, CS1  - controlled via SPICS override register
+ *   CS2, CS3  - controlled via GPIOs (cs-gpios in DT)
+ *
+ * On Salina, the wiring is different:
+ *
+ *   - Only CS0 and CS1 are physically used (via SPICS override)
+ *   - CS2 and CS3 are not used as independent chip selects
+ *   - CS0 selects the CPLD registers (the same as Elba).
+ *   - CPLD register DPU_CSMAP selects the other devices.
+ *
+ * CPLD mux operation via CPLD register 0x05 (DPU_CSMAP)
+ * -----------------------------------------------------
+ *
+ *   CPLD register 0x05 (DPU_CSMAP) - Virtual CS
+ *
+ *   Value  Description
+ *   -----  ------------------------------------------
+ *   0x00   Disabled
+ *   0x01   CPLD internal flash
+ *   0x02   Lattice RD1173 (SPI-to-I2C bridge)
+ *   0x03   SMBus over SPI
+ *
+ * Accessing a downstream device requires:
+ *
+ *   1. Write the selector via CS0 (CPLD register space)
+ *   2. Perform the SPI transfer via CS1 (shared data path)
+ *
+ * SPI controller behavior
+ * -----------------------
+ *
+ * The DesignWare SPI controller still requires a "native" chip select
+ * to be asserted to start the serial engine. This driver reuses the
+ * existing Elba logic:
+ *
+ *   - The controller is always kicked using native CS0
+ *   - SPICS override selects the actual external chip (CS0 or CS1)
+ *
+ * Effectively:
+ *
+ *   - CS0 => CPLD register space
+ *   - CS1 => multiplexed data path
+ *   - CS2/CS3 => unused on Salina
+ *
+ * Virtual SPI controller
+ * ----------------------
+ *
+ * To present a standard SPI interface to clients, this driver creates
+ * a virtual SPI controller:
+ *
+ *   Virtual CS    Operation
+ *   ----------    --------------------------------------------
+ *   CS0           Direct access to CPLD register space (CS0)
+ *   CS1..CS3      1) Write CSMAP via CS0
+ *                 2) Forward transfer via physical CS1
+ *
+ * This keeps SPI client drivers (e.g. RD1173) unaware of the CPLD mux
+ * and avoids embedding mux logic into individual drivers.
+ */
+
+#include <linux/module.h>
+#include <linux/spi/spi.h>
+#include <linux/of.h>
+#include <linux/of_device.h>
+
+/* CPLD definitions */
+#define CPLD_CMD_WR	0x02
+#define CPLD_REG_CSMAP	0x05
+
+#define CPLD_SPI_HZ 5000000
+
+struct cpld_mux {
+	struct spi_controller *ctlr;
+	struct spi_device *parent_spi;	/* physical CS0 device */
+	struct mutex lock;
+	u8 current_cs;
+};
+
+/* Safely forward a SPI message to the parent controller */
+static int cpld_mux_forward(struct cpld_mux *mux,
+			    struct spi_message *msg)
+{
+	struct spi_message new_msg;
+	int ret;
+
+	spi_message_init(&new_msg);
+
+	/* Move transfers from original message */
+	list_splice_tail_init(&msg->transfers, &new_msg.transfers);
+
+	/* Execute on parent SPI device */
+	ret = spi_sync(mux->parent_spi, &new_msg);
+
+	/* Copy results back */
+	msg->status = new_msg.status;
+	msg->actual_length = new_msg.actual_length;
+
+	return ret;
+}
+
+static int cpld_mux_select(struct cpld_mux *mux, u8 cs)
+{
+	u8 tx[3] = { CPLD_CMD_WR, CPLD_REG_CSMAP, cs };
+	struct spi_transfer t = {
+		.tx_buf = tx,
+		.len = sizeof(tx),
+		.speed_hz = CPLD_SPI_HZ,
+		.bits_per_word = 8
+	};
+	struct spi_message m;
+	int ret;
+
+	if (mux->current_cs == cs)
+		return 0;
+
+	/* Force physical CS=0 for CPLD register access */
+	spi_set_chipselect(mux->parent_spi, 0, 0);
+
+	spi_message_init(&m);
+	spi_message_add_tail(&t, &m);
+
+	ret = cpld_mux_forward(mux, &m);
+	if (ret)
+		dev_info(&mux->parent_spi->dev, "Error writing CSMAP\n");
+
+	return ret;
+}
+
+static int cpld_mux_transfer_one_message(struct spi_controller *ctlr,
+					 struct spi_message *msg)
+{
+	struct cpld_mux *mux = spi_controller_get_devdata(ctlr);
+	struct spi_device *spi = msg->spi;
+	int cs = spi_get_chipselect(spi, 0);
+	int ret;
+
+	mutex_lock(&mux->lock);
+
+	if (cs == 0) {
+		/* Direct pass-through to CPLD register space */
+		ret = cpld_mux_forward(mux, msg);
+	} else {
+		/*
+		 * Route via CPLD mux:
+		 *  - write CSMAP register (CS0)
+		 *  - send data via CS1
+		 */
+
+		/* Select CPLD target */
+		ret = cpld_mux_select(mux, cs);
+		if (ret) {
+			dev_err(&spi->dev, "mux select failed for CS%d\n", cs);
+			goto out;
+		}
+
+		/*
+		 * Set physical CS=1 for the upcoming transfer.  The block
+		 * in the CPLD receiving the transfer has just been set by
+		 * writing to the CSMAP register.
+		 */
+		spi_set_chipselect(mux->parent_spi, 0, 1);
+
+		/* Forward full message */
+		ret = cpld_mux_forward(mux, msg);
+
+		/* Restore CS0 */
+		spi_set_chipselect(mux->parent_spi, 0, 0);
+	}
+
+out:
+	mutex_unlock(&mux->lock);
+
+	spi_finalize_current_message(ctlr);
+
+	return ret;
+}
+
+static int cpld_mux_setup(struct spi_device *spi)
+{
+	return 0;
+}
+
+static int cpld_mux_probe(struct spi_device *spi)
+{
+	struct spi_controller *ctlr;
+	struct cpld_mux *mux;
+	int ret;
+
+	ctlr = spi_alloc_master(&spi->dev, sizeof(*mux));
+	if (!ctlr)
+		return -ENOMEM;
+
+	mux = spi_controller_get_devdata(ctlr);
+	mux->ctlr = ctlr;
+	mux->parent_spi = spi;	/* physical CS0 path */
+	mux->current_cs = 0xff;
+	mutex_init(&mux->lock);
+
+	ctlr->mode_bits = SPI_MODE_0;
+	ctlr->num_chipselect = 4;
+	ctlr->setup = cpld_mux_setup;
+	ctlr->transfer_one_message = cpld_mux_transfer_one_message;
+	ctlr->dev.of_node = spi->dev.of_node;
+
+	ret = spi_register_controller(ctlr);
+	if (ret) {
+		spi_controller_put(ctlr);
+		return ret;
+	}
+
+	spi_set_drvdata(spi, mux);
+
+	dev_info(&spi->dev, "CPLD SPI mux initialized\n");
+
+	return 0;
+}
+
+static void cpld_mux_remove(struct spi_device *spi)
+{
+	struct cpld_mux *mux = spi_get_drvdata(spi);
+
+	spi_unregister_controller(mux->ctlr);
+}
+
+static const struct of_device_id cpld_mux_of_match[] = {
+	{ .compatible = "amd,pensando-cpld-spimux" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, cpld_mux_of_match);
+
+static const struct spi_device_id cpld_mux_spi_ids[] = {
+	{ "pensando-cpld-spimux" },
+	{ }
+};
+MODULE_DEVICE_TABLE(spi, cpld_mux_spi_ids);
+
+static struct spi_driver cpld_mux_driver = {
+	.driver = {
+		.name = "cpld-spimux",
+		.of_match_table = cpld_mux_of_match,
+	},
+	.id_table = cpld_mux_spi_ids,
+	.probe = cpld_mux_probe,
+	.remove = cpld_mux_remove,
+};
+
+module_spi_driver(cpld_mux_driver);
+
+MODULE_LICENSE("GPL");
