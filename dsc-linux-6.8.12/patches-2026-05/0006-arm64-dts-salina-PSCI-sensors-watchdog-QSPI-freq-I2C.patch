 arch/arm64/boot/dts/amd/salina-n1-common.dtsi |  14 +-
 arch/arm64/boot/dts/amd/salina-secure.dts     |  61 ++++++
 arch/arm64/configs/salina_defconfig           |   2 +-
 12 files changed, 382 insertions(+), 205 deletions(-)
 create mode 100644 arch/arm64/boot/dts/amd/salina-16core-psci.dtsi
