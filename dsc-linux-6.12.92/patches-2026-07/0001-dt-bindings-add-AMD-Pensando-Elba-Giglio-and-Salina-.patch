+# SPDX-License-Identifier: (GPL-2.0 OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/soc/pensando/pensando,uio.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: AMD Pensando UIO platform devices
+
+maintainers:
+  - Brad Larson <blarson@amd.com>
+
+description:
+  UIO devices used by AMD Pensando platform software for MSI, PCIe MAC,
+  and link MAC access.
+
+properties:
+  compatible:
+    enum:
+      - pensando,uio_penmsi
+      - pensando,uio_penmsi1
+      - pensando,uio_pciemac
+      - pensando,uio_linkmac
+
+  reg:
+    minItems: 1
+    maxItems: 16
+
+  interrupts:
+    minItems: 1
+    maxItems: 32
+
+  num-interrupts:
+    $ref: /schemas/types.yaml#/definitions/uint32
+    description:
+      Number of platform MSI interrupts to allocate.
+
+  name:
+    $ref: /schemas/types.yaml#/definitions/string
+    description:
+      Optional userspace-visible UIO device name.
+
+required:
+  - compatible
+
+allOf:
+  - if:
+      properties:
+        compatible:
+          contains:
+            enum:
+              - pensando,uio_penmsi
+              - pensando,uio_penmsi1
+    then:
+      required:
+        - num-interrupts
+
+additionalProperties: true
+
+examples:
+  - |
+    uio_penmsi {
+        compatible = "pensando,uio_penmsi";
+        num-interrupts = <1>;
+    };
+
+  - |
+    uio_penmsi1 {
+        compatible = "pensando,uio_penmsi1";
+        num-interrupts = <1>;
+    };
+
+  - |
+    uio_pciemac {
+        compatible = "pensando,uio_pciemac";
+    };
+
+  - |
+    uio_linkmac {
+        compatible = "pensando,uio_linkmac";
+    };
diff --git a/Documentation/devicetree/bindings/spi/amd,pensando-cpld-rd1173.yaml b/Documentation/devicetree/bindings/spi/amd,pensando-cpld-rd1173.yaml
