 arch/arm64/boot/dts/amd/salina-asic.dtsi      |   9 +
 arch/arm64/configs/salina_defconfig           |   1 +
 arch/arm64/configs/salina_gold_defconfig      |   2 +
 drivers/edac/Kconfig                          |   8 +
 drivers/edac/Makefile                         |   1 +
 drivers/edac/salina_edac.c                    | 282 ++++++++++++++++++
 7 files changed, 307 insertions(+)
