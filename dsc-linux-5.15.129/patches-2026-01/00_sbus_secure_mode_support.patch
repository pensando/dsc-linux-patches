-	args.regs[0] = PEN_SBUS_SMC_CALL_FID;
-	args.regs[1] = PEN_SBUS_SMC_REG_READ;
-	args.regs[2] = (uint64_t)addr;
-
-	arm_smccc_smc(args.regs[0], args.regs[1], args.regs[2], 0, 0, 0,
