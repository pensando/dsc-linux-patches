From 32b5e606ebc4eced3609b88be824842c7a0f1099 Mon Sep 17 00:00:00 2001
From: rahshekh <rahulshekhar@pensando.io>
Date: Tue, 26 May 2026 14:34:56 -0700
Subject: [PATCH 5/8] i2c: rd1173: Salina support, reset on error, restore
 interrupt clear

- i2c: rd1173: add Salina support
- i2c: rd1173: reset port on transfer error
- i2c: rd1173: Restore interrupt clear
---
 arch/arm64/boot/dts/amd/salina-n1-common.dtsi |   1 +
 drivers/i2c/busses/i2c-rd1173.c               | 364 +++++++++---------
 2 files changed, 190 insertions(+), 175 deletions(-)

diff --git a/arch/arm64/boot/dts/amd/salina-n1-common.dtsi b/arch/arm64/boot/dts/amd/salina-n1-common.dtsi
index 4f75873cc422..8ca0c303dd27 100644
--- a/arch/arm64/boot/dts/amd/salina-n1-common.dtsi
+++ b/arch/arm64/boot/dts/amd/salina-n1-common.dtsi
@@ -54,6 +54,7 @@ spi@2 {
 			compatible = "amd,pensando-cpld-rd1173";
 			reg = <2>;
 			spi-max-frequency = <12000000>;
+			interrupt-gpios = <&porta 0 GPIO_ACTIVE_LOW>;
 			interrupt-parent = <&porta>;
 			interrupts = <0 IRQ_TYPE_LEVEL_LOW>;
 		};
diff --git a/drivers/i2c/busses/i2c-rd1173.c b/drivers/i2c/busses/i2c-rd1173.c
