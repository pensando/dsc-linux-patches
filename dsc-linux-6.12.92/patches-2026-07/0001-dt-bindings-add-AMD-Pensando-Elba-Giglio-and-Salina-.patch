+# SPDX-License-Identifier: (GPL-2.0 OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/spi/amd,pensando-cpld-spimux.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: AMD Pensando CPLD SPI mux
+
+maintainers:
+  - Brad Larson <blarson@amd.com>
+
+description:
+  The AMD Pensando Salina CPLD contains a register selected SPI mux.  CS0
+  accesses CPLD registers and virtual chip selects route transactions to
+  CPLD internal flash, the RD1173 I2C bridge, and SMBus-over-SPI logic.
+
+properties:
+  compatible:
+    const: amd,pensando-cpld-spimux
+
+  reg:
+    maxItems: 1
+
+  spi-max-frequency: true
+
+  '#address-cells':
+    const: 1
+
+  '#size-cells':
+    const: 0
+
+required:
+  - compatible
+  - reg
+  - '#address-cells'
+  - '#size-cells'
+
+additionalProperties:
+  type: object
+
+examples:
+  - |
+    spi {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        spi@0 {
+            compatible = "amd,pensando-cpld-spimux";
+            reg = <0>;
+            spi-max-frequency = <12000000>;
+            #address-cells = <1>;
+            #size-cells = <0>;
+
+            i2c-bridge@2 {
+                compatible = "amd,pensando-cpld-rd1173";
+                reg = <2>;
+                spi-max-frequency = <12000000>;
+            };
+        };
+    };
+
+...
