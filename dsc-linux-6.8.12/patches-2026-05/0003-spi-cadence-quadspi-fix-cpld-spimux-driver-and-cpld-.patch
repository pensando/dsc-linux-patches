diff --git a/drivers/i2c/busses/i2c-designware-common.c b/drivers/i2c/busses/i2c-designware-common.c
index 1b6899d47a96..65999ad95c2b 100644
--- a/drivers/i2c/busses/i2c-designware-common.c
+++ b/drivers/i2c/busses/i2c-designware-common.c
@@ -484,6 +484,32 @@ void __i2c_dw_disable(struct dw_i2c_dev *dev)
 	dev_warn(dev->dev, "timeout in disabling adapter\n");
 }
 
+/**
+ * i2c_dw_set_mode - switch controller between master and slave mode
+ * @dev: device private data
+ * @mode: DW_IC_MASTER or DW_IC_SLAVE
+ *
+ * Required for MCTP-over-I2C (BMC master → Linux slave RX, then Linux master TX response).
+ */
+void i2c_dw_set_mode(struct dw_i2c_dev *dev, int mode)
+{
+	if (dev->mode == mode)
+		return;
+
+	__i2c_dw_disable(dev);
+
+	if (mode == DW_IC_MASTER)
+		i2c_dw_configure_fifo_master(dev);
+	else
+		i2c_dw_configure_fifo_slave(dev);
+
+	dev->mode = mode;
+
+	__i2c_dw_enable(dev);
+}
+EXPORT_SYMBOL_GPL(i2c_dw_set_mode);
+
+
 u32 i2c_dw_clk_rate(struct dw_i2c_dev *dev)
 {
 	/*
