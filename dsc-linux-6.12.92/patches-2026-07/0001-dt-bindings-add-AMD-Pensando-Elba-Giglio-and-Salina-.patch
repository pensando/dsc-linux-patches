diff --git a/Documentation/devicetree/bindings/mfd/amd,pensando-elbasr.yaml b/Documentation/devicetree/bindings/mfd/amd,pensando-elbasr.yaml
new file mode 100644
index 000000000000..97a0dc57cbc0
--- /dev/null
+++ b/Documentation/devicetree/bindings/mfd/amd,pensando-elbasr.yaml
@@ -0,0 +1,103 @@
+# SPDX-License-Identifier: (GPL-2.0 OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/mfd/amd,pensando-elbasr.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: AMD Pensando Elba SoC Resource Controller
+
+description: |
+  AMD Pensando Elba SoC Resource Controller attached to a SPI bus.
+  The device may expose reset controller and other child devices.
+
+maintainers:
+  - Brad Larson <bradley.larson@amd.com>
+
+properties:
+  compatible:
+    items:
+      - const: amd,pensando-elbasr
+      - const: simple-mfd
+
+  reg:
+    maxItems: 1
+
+  spi-max-frequency:
+    description: Maximum SPI frequency of the device in Hz.
+
+  '#address-cells':
+    const: 1
+
+  '#size-cells':
+    const: 0
+
+  interrupts:
+    maxItems: 1
+
+  rtc:
+    type: object
+    additionalProperties: false
+    description:
+      Optional RTC routed through the CPLD, present only on cards that wire an
+      FPGA RTC to the resource controller. Register access is provided by the
+      parent elbasr SPI regmap, so the node carries no reg of its own.
+    properties:
+      compatible:
+        const: amd,pensando-elbasr-rtc
+    required:
+      - compatible
+
+required:
+  - compatible
+  - reg
+  - spi-max-frequency
+
+patternProperties:
+  '^reset-controller@[0-9a-f]+$':
+    $ref: /schemas/reset/amd,pensando-elbasr-reset.yaml#
+
+additionalProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/reset/amd,pensando-elba-reset.h>
+    #include <dt-bindings/interrupt-controller/arm-gic.h>
+
+    spi {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        spi@0 {
+            compatible = "amd,pensando-elbasr", "simple-mfd";
+            reg = <0>;
+            spi-max-frequency = <12000000>;
+            #address-cells = <1>;
+            #size-cells = <0>;
+
+            rstc: reset-controller@0 {
+                compatible = "amd,pensando-elbasr-reset";
+                reg = <0>;
+                #reset-cells = <1>;
+            };
+        };
+
+        spi@1 {
+            compatible = "amd,pensando-elbasr", "simple-mfd";
+            reg = <1>;
+            spi-max-frequency = <12000000>;
+        };
+
+        spi@2 {
+            compatible = "amd,pensando-elbasr", "simple-mfd";
+            reg = <2>;
+            spi-max-frequency = <12000000>;
+            interrupt-parent = <&porta>;
+            interrupts = <0 IRQ_TYPE_LEVEL_LOW>;
+        };
+
+        spi@3 {
+            compatible = "amd,pensando-elbasr", "simple-mfd";
+            reg = <3>;
+            spi-max-frequency = <12000000>;
+        };
+    };
