-static int of_get_secure_mode(void)
-{
-	struct device_node *of_secure_mode;
-	int enable = 0;
-
-	/* Get secure mode from OF */
-	of_secure_mode = of_find_node_by_path("/secure_mode");
-	if (of_secure_mode) {
