-#define RD1173_STAT_TX_ERR        0x10
-#define RD1173_STAT_RX_ERR        0x08
-#define RD1173_STAT_ABORT_ACK     0x04
-#define RD1173_STAT_TS            0x02
+#define RD1173_STAT_I2C_BUSY	  0x80
+#define RD1173_STAT_NO_ANS	  0x40
