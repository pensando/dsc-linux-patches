+				core1 { cpu = <&cpu9>; };
+			};
+			cluster5 {
+				core0 { cpu = <&cpu10>; };
+				core1 { cpu = <&cpu11>; };
+			};
+			cluster6 {
+				core0 { cpu = <&cpu12>; };
+				core1 { cpu = <&cpu13>; };
+			};
+			cluster7 {
+				core0 { cpu = <&cpu14>; };
+				core1 { cpu = <&cpu15>; };
+			};
+		};
