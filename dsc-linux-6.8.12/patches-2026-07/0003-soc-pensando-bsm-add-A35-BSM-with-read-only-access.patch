From 0ffc6c9e3486b3a9ea78fd5a96c019a74cd95877 Mon Sep 17 00:00:00 2001
From: Hiren Mehta <hiren.mehta@amd.com>
Date: Tue, 7 Jul 2026 17:18:01 -0700
Subject: soc/pensando/bsm: add A35 BSM with read-only access from N1 

Add a second BSM (bsm_a35) for the A35 subsystem alongside the
existing N1 BSM. Refactor cap_bsm.c to support multiple instances,
iterating all pensando,bsm DT nodes. Expose both as separate sysfs
entries under /sys/firmware/pensando/.

The A35 BSM is read-only from N1 Linux -- N1 can read A35 BSM fields
but cannot modify it. A35 retains sole ownership of its BSM state.
The N1 BSM remains read-writable.

Signed-off-by: Hiren Mehta <hiren.mehta@amd.com>
---
 arch/arm64/boot/dts/amd/salina-asic.dtsi |  11 +++
 arch/arm64/configs/salina_defconfig      |   1 +
 arch/arm64/configs/salina_gold_defconfig |   2 +
 drivers/soc/pensando/cap_bsm.c           | 113 +++++++++++++++--------
 4 files changed, 91 insertions(+), 36 deletions(-)

diff --git a/arch/arm64/boot/dts/amd/salina-asic.dtsi b/arch/arm64/boot/dts/amd/salina-asic.dtsi
index 3ba05acc6e0c..bfbb09a42ddd 100644
--- a/arch/arm64/boot/dts/amd/salina-asic.dtsi
+++ b/arch/arm64/boot/dts/amd/salina-asic.dtsi
@@ -357,6 +357,17 @@ wdt3: watchdog@80000 {
 			status = "disabled";
 		};
 
+		bsm: bsm@6100020c {
+			compatible = "pensando,bsm";
+			reg = <0x0 0x6100020c 0x0 0x4>;
+		};
+
+		bsm_a35: bsm_a35@61000200 {
+			compatible = "pensando,bsm";
+			reg = <0x0 0x61000200 0x0 0x4>;
+			read-only;
+		};
+
 		panic: panicdump {
 			compatible = "pensando,capri-crash";
 			status = "disabled";
diff --git a/arch/arm64/configs/salina_defconfig b/arch/arm64/configs/salina_defconfig
index f2803ab192d8..f482f1ab9cb5 100644
--- a/arch/arm64/configs/salina_defconfig
+++ b/arch/arm64/configs/salina_defconfig
@@ -251,6 +251,7 @@ CONFIG_COMMON_CLK_CS2000_CP=y
 # CONFIG_ARM64_ERRATUM_858921 is not set
 # CONFIG_IOMMU_SUPPORT is not set
 CONFIG_ARCH_PENSANDO_SALINA_SOC=y
+CONFIG_PENSANDO_SOC_BSM=y
 CONFIG_PENSANDO_SOC_BSM_ENABLE=y
 CONFIG_PENSANDO_SOC_PENFW=y
 CONFIG_EXTCON=y
diff --git a/arch/arm64/configs/salina_gold_defconfig b/arch/arm64/configs/salina_gold_defconfig
index bc25795c1cc4..48598f5a2fb5 100644
--- a/arch/arm64/configs/salina_gold_defconfig
+++ b/arch/arm64/configs/salina_gold_defconfig
@@ -256,6 +256,8 @@ CONFIG_COMMON_CLK_CS2000_CP=y
 # CONFIG_ARM64_ERRATUM_858921 is not set
 # CONFIG_IOMMU_SUPPORT is not set
 CONFIG_ARCH_PENSANDO_SALINA_SOC=y
+CONFIG_PENSANDO_SOC_BSM=y
+CONFIG_PENSANDO_SOC_BSM_ENABLE=y
 CONFIG_PENSANDO_SOC_PENFW=y
 CONFIG_EXTCON=y
 CONFIG_GENERIC_PHY=y
diff --git a/drivers/soc/pensando/cap_bsm.c b/drivers/soc/pensando/cap_bsm.c
index 5a99cb7c4900..0a5bcd00008d 100644
--- a/drivers/soc/pensando/cap_bsm.c
+++ b/drivers/soc/pensando/cap_bsm.c
@@ -14,15 +14,21 @@ extern struct kobject *pensando_fw_kobj_get(void);
 
 struct bsm {
 	void __iomem *base;
+	resource_size_t phys;
 	uint32_t val;
+	bool read_only;
 };
-static struct bsm bsm;
+
+#define BSM_MAX_INSTANCES 4
+static struct bsm bsm_instances[BSM_MAX_INSTANCES];
+static int bsm_count;
 
 #define BSM_SHOW_INT(n, s) \
 	static ssize_t n##_show(struct device *dev,			\
 			struct device_attribute *attr, char *buf)	\
 	{								\
-		int val = (bsm.val >> BSM_##s##_LSB) & BSM_##s##_MASK;	\
+		struct bsm *b = dev_get_drvdata(dev);			\
+		int val = (b->val >> BSM_##s##_LSB) & BSM_##s##_MASK;	\
 		return sprintf(buf, "%d\n", val);			\
 	}								\
 	static DEVICE_ATTR_RO(n)
@@ -41,7 +47,8 @@ static const char *fwnames[4] = {
 	static ssize_t n##_show(struct device *dev,			\
 			struct device_attribute *attr, char *buf)	\
 	{								\
-		int val = (bsm.val >> BSM_##s##_LSB) & BSM_##s##_MASK;	\
+		struct bsm *b = dev_get_drvdata(dev);			\
+		int val = (b->val >> BSM_##s##_LSB) & BSM_##s##_MASK;	\
 		return sprintf(buf, "%s\n", fwnames[val & 0x3]);	\
 	}								\
 	static DEVICE_ATTR_RO(n)
@@ -52,13 +59,17 @@ BSM_SHOW_FWID(track, TRACK);
 static ssize_t success_store(struct device *dev,
 		struct device_attribute *attr, const char *buf, size_t count)
 {
+	struct bsm *b = dev_get_drvdata(dev);
 	long val;
 
+	if (b->read_only)
+		return -EPERM;
+
 	if (kstrtoul(buf, 0, &val) < 0)
 		return -EINVAL;
 	if (val) {
-		bsm.val &= ~(1 << BSM_RUNNING_LSB);
-		writel(bsm.val, bsm.base);
+		b->val &= ~(1 << BSM_RUNNING_LSB);
+		writel(b->val, b->base);
 	}
 
 	return count;
@@ -76,18 +87,41 @@ static const struct device_attribute *bsm_attrs[] = {
 	&dev_attr_success,
 };
 
+static const struct of_device_id bsm_of_match[] = {
+	{ .compatible = "pensando,bsm" },
+	{ }
+};
+
 static int bsm_probe(struct platform_device *pdev)
 {
 	struct kobject *pensando_kobj;
+	struct resource *res;
+	struct bsm *b = NULL;
+	const char *symlink_name;
 	int i, r = 0;
 
-	if (bsm.base == NULL) {
-		/* bsm not in device-tree */
+	res = platform_get_resource(pdev, IORESOURCE_MEM, 0);
+	if (!res)
 		return -ENODEV;
+
+	/* Find the pre-mapped instance from early init by physical address */
+	for (i = 0; i < bsm_count; i++) {
+		if (bsm_instances[i].phys == res->start) {
+			b = &bsm_instances[i];
+			break;
+		}
 	}
+	if (!b) {
+		pr_err("bsm: no early-init data for %pa\n", &res->start);
+		return -ENODEV;
+	}
+
+	platform_set_drvdata(pdev, b);
+
 	pensando_kobj = pensando_fw_kobj_get();
 	if (!pensando_kobj)
 		return -ENOMEM;
+
 	for (i = 0; i < ARRAY_SIZE(bsm_attrs); i++) {
 		r = device_create_file(&pdev->dev, bsm_attrs[i]);
 		if (r) {
@@ -95,7 +129,9 @@ static int bsm_probe(struct platform_device *pdev)
 			return r;
 		}
 	}
-	r = sysfs_create_link(pensando_kobj, &pdev->dev.kobj, "bsm");
+
+	symlink_name = pdev->dev.of_node ? pdev->dev.of_node->name : dev_name(&pdev->dev);
+	r = sysfs_create_link(pensando_kobj, &pdev->dev.kobj, symlink_name);
 	if (r) {
 		pr_err("failed to create sysfs symlink\n");
 		kobject_put(pensando_kobj);
@@ -104,10 +140,6 @@ static int bsm_probe(struct platform_device *pdev)
 	return 0;
 }
 
-static const struct of_device_id bsm_of_match[] = {
-	{ .compatible = "pensando,bsm" },
-};
-
 static struct platform_driver bsm_driver = {
 	.driver = {
 		.name = "elba-bsm",
@@ -120,40 +152,49 @@ builtin_platform_driver(bsm_driver);
 
 /*
  * Boot State Machine init.
- * If auto-booting, then set the BSM_RUNNING bit in the BSM register
- * to continue BSM protection.	The bit will be cleared when userland comes up.
+ * Find all BSM nodes in device tree, map their registers, and if
+ * auto-booting set the BSM_RUNNING bit to continue BSM protection.
+ * The bit will be cleared when userland comes up.
  */
 static int __init cap_bsm_init(void)
 {
 	const struct of_device_id *match;
-	struct device_node *np;
+	struct device_node *np = NULL;
 	struct resource res;
 
-	np = of_find_matching_node_and_match(NULL, bsm_of_match, &match);
-	if (!np) {
-		/* Not found in the device-tree.  Quietly resign */
-		return 0;
-	}
-	if (of_address_to_resource(np, 0, &res) < 0) {
-		pr_err("failed to get BSM registers\n");
-		of_node_put(np);
-		return -ENXIO;
-	}
-	of_node_put(np);
+	while ((np = of_find_matching_node_and_match(np, bsm_of_match, &match))) {
+		struct bsm *b;
 
-	bsm.base = ioremap(res.start, resource_size(&res));
-	if (!bsm.base) {
-		pr_err("failed to map BSM register\n");
-		return -ENXIO;
-	}
+		if (bsm_count >= BSM_MAX_INSTANCES) {
+			pr_warn("bsm: too many BSM instances, skipping %s\n", np->name);
+			of_node_put(np);
+			break;
+		}
 
-	bsm.val = readl(bsm.base);
+		if (of_address_to_resource(np, 0, &res) < 0) {
+			pr_err("bsm: failed to get registers for %s\n", np->name);
+			continue;
+		}
+
+		b = &bsm_instances[bsm_count];
+		b->phys = res.start;
+		b->read_only = of_property_read_bool(np, "read-only");
+		b->base = ioremap(res.start, resource_size(&res));
+		if (!b->base) {
+			pr_err("bsm: failed to map register for %s\n", np->name);
+			continue;
+		}
+
+		b->val = readl(b->base);
 #ifdef CONFIG_PENSANDO_SOC_BSM_ENABLE
-	if (bsm.val & (1 << BSM_AUTOBOOT_LSB)) {
-		bsm.val |= 1 << BSM_RUNNING_LSB;
-		writel(bsm.val, bsm.base);
-	}
+		if (!b->read_only && (b->val & (1 << BSM_AUTOBOOT_LSB))) {
+			b->val |= 1 << BSM_RUNNING_LSB;
+			writel(b->val, b->base);
+		}
 #endif
+		bsm_count++;
+	}
+
 	return 0;
 }
 early_initcall(cap_bsm_init);
