diff --git a/arch/arm64/boot/dts/amd/salina-asic-common.dtsi b/arch/arm64/boot/dts/amd/salina-asic-common.dtsi
new file mode 100644
index 000000000000..db72a31c0c7c
--- /dev/null
+++ b/arch/arm64/boot/dts/amd/salina-asic-common.dtsi
@@ -0,0 +1,87 @@
+// SPDX-License-Identifier: (GPL-2.0-only or BSD-2-Clause)
+/*
+ * Copyright 2023-2024 Advanced Micro Devices, Inc.
+ */
+
+#include <dt-bindings/i2c/i2c.h>
+
+&spi0 {
+	status = "okay";
+};
+
+&spi1 {
+	status = "okay";
+};
+
+&emmc_clk {
+	clock-frequency = <208000000>;
+};
+
+&emmc0 {
+	bus-width = <8>;
+	cap-mmc-hw-reset;
+	reset-names = "hw";
+	status = "ok";
+};
+
+&i2c1 {
+	clock-frequency = <100000>;
+	status = "disabled";
+};
+
+&i2c2 {
+	clock-frequency = <100000>;
+	status = "okay";
+
+	temp-sensor@4c {
+		compatible = "ti,tmp451";
+		reg = <0x4c>;
+	};
+
+	ina3221@43 {
+		compatible = "ti,ina3221";
+		reg = <0x43>;
+		#address-cells = <1>;
+		#size-cells = <0>;
+
+		input@0 {
+			reg = <0>;
+			label = "P12VDIN";
+			shunt-resistor-micro-ohms = <2000>;
+		};
+
+		input@1 {
+			reg = <1>;
+			label = "V33";
+			shunt-resistor-micro-ohms = <1000>;
+		};
+
+		input@2 {
+			reg = <2>;
+			label = "VDDR";
+			shunt-resistor-micro-ohms = <1000>;
+		};
+	};
+
+	rtc@51 {
+		compatible = "nxp,pcf85263";
+		reg = <0x51>;
+	};
+
+	regulator@60 {
+		compatible = "ti,tps53659";
+		reg = <0x60>;
+	};
+};
+
+&i2c3 {
+	clock-frequency = <100000>;
+	multi-master;
+	mctp-controller;
+	status = "okay";
+
+	mctp@32 {
+		compatible = "mctp-i2c-controller";
+		reg = <(0x32 | I2C_OWN_SLAVE_ADDRESS)>;
+	};
+};
diff --git a/arch/arm64/boot/dts/amd/salina-asic-psci.dts b/arch/arm64/boot/dts/amd/salina-asic-psci.dts
new file mode 100644
index 000000000000..87d77d99a92a
--- /dev/null
+++ b/arch/arm64/boot/dts/amd/salina-asic-psci.dts
@@ -0,0 +1,52 @@
+// SPDX-License-Identifier: (GPL-2.0-only or BSD-2-Clause)
+/*
+ * Device Tree file for AMD Pensando Salina Board.
+ *
+ * Copyright 2023-2024 Advanced Micro Devices, Inc.
+ */
+
+/dts-v1/;
+
+#include "salina-asic.dtsi"
+#include "salina-16core.dtsi"
+#include "salina-16core-psci.dtsi"
+#include "salina-n1-common.dtsi"
+#include "salina-n1-flash-parts.dtsi"
+#include "elba-asic-memory.dtsi"
+#include "elba-mdev.dtsi"
+#include "salina-asic-common.dtsi"
+
+/ {
+	model = "Salina ASIC Board";
+	compatible = "pensando,salina";
+
+	aliases {
+		serial1 = &uart1;
+		spi0 = &spi0;
+		spi1 = &spi1;
+		i2c0 = &i2c1;	/* i2c@20000 -> Linux i2c-0 */
+		i2c1 = &i2c2;   /* i2c@30000 -> Linux i2c-1 (Sensors) */
+		i2c2 = &i2c3;   /* i2c@40000 -> Linux i2c-2 (MCTP) */
+	};
+
+	chosen {
+		stdout-path = "serial1:115200n8";
+	};
+
+	tawkipc {
+		compatible = "amd,tawk-ipc";
+		peer-id = <1>;
+		#address-cells = <2>;
+		#size-cells = <1>;
+		reg = <0x0 0x0 0x0 0x0>,  /* doorbells */
+			<0x0 0x0 0x0 0x0>, /* msix-like table */
+			<0x47 0xe1d2b100 0x0 0x8>,  /* reset signal registers */
+			<0x47 0xe1d2c100 0x0 0x10>,     /* mailbox control registers */
+			<0x47 0xe1d2d100 0x0 0x800>;    /* mailbox buffers */
+		rst-sigs = <0x4 0x0>;
+		nmboxes = <2>;
+		mbox-ctl = <0x0 0x3>;
+		mbox-buf = <0x0 0xa 0x400>;
+		status = "okay";
+	};
+};
