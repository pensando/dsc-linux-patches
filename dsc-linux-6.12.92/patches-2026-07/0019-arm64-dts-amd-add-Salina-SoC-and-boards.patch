+
+		cpu9: cpu@90000 {
+			device_type = "cpu";
+			compatible = "arm,neoverse-n1";
+			reg = <0 0x90000>;
+		};
+
+		/* CLUSTER 5 */
+		cpu10: cpu@a0000 {
+			device_type = "cpu";
+			compatible = "arm,neoverse-n1";
+			reg = <0 0xa0000>;
+		};
+
+		cpu11: cpu@b0000 {
+			device_type = "cpu";
