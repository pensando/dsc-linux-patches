+		cpu0: cpu@0 {
+			device_type = "cpu";
+			compatible = "arm,neoverse-n1";
+			reg = <0 0>;
+		};
+
+		cpu1: cpu@10000 {
+			device_type = "cpu";
+			compatible = "arm,neoverse-n1";
+			reg = <0 0x10000>;
+		};
+
+		/* CLUSTER 1 */
+		cpu2: cpu@20000 {
+			device_type = "cpu";
+			compatible = "arm,neoverse-n1";
+			reg = <0 0x20000>;
+		};
+
+		cpu3: cpu@30000 {
+			device_type = "cpu";
+			compatible = "arm,neoverse-n1";
+			reg = <0 0x30000>;
+		};
+
+		/* CLUSTER 2 */
