+			cluster0 {
+				core0 { cpu = <&cpu0>; };
+				core1 { cpu = <&cpu1>; };
+			};
+			cluster1 {
+				core0 { cpu = <&cpu2>; };
+				core1 { cpu = <&cpu3>; };
+			};
+			cluster2 {
+				core0 { cpu = <&cpu4>; };
+				core1 { cpu = <&cpu5>; };
+			};
+			cluster3 {
+				core0 { cpu = <&cpu6>; };
+				core1 { cpu = <&cpu7>; };
+			};
+			cluster4 {
