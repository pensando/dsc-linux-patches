@@ -471,7 +824,9 @@ static void sdhci_cdns_mmc_hw_reset(struct mmc_host *mmc)
 	struct sdhci_host *host = mmc_priv(mmc);
 	struct sdhci_cdns_priv *priv = sdhci_cdns_priv(host);
 
-	dev_dbg(mmc_dev(host->mmc), "emmc hardware reset\n");
