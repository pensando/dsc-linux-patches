-	case RD1173_STAT_TX_ERR:
-	case RD1173_STAT_RX_ERR:
-	case RD1173_STAT_ABORT_ACK:
+
+	if (ret < 0 && (i2c->state & RD1173_RESET_ERRORS))
 		rd1173_reset(i2c);
